macos-option-as-alt = true
theme = Catppuccin Mocha
background = 111820
foreground = ffffff
term = xterm-256color

# Window Geometry
window-padding-x = 20
window-padding-y = 20

# Font
# font-family = "MenloLGS NF"
font-size = 14

# Start Directory
working-directory = /Users/JK/_Work

# Quick terminal (global)
keybind = global:ctrl+alt+backquote=toggle_quick_terminal
quick-terminal-position=right
quick-terminal-size=20%
quick-terminal-screen=main
quit-after-last-window-closed=false